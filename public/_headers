# Cloudflare Pages headers config.
# Replicates the headers() function removed from next.config.ts when we
# switched to output: "export". Pyodide ships ~12MB of immutable wasm/asm.js
# per release; long-cache so repeat visitors don't redownload every lesson.
# No `immutable` keyword — files in /public aren't content-hashed, so a
# force-refresh must still revalidate after a pyodide version bump.

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/pyodide/*
  Cache-Control: public, max-age=31536000

/pyodide-worker.js
  Cache-Control: public, max-age=31536000
