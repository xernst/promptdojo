{
  "name": "promptdojo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:content:v1": "node scripts/build-content.mjs",
    "build:content:v2": "node scripts/build-content-v2.mjs",
    "build:content": "node scripts/build-content.mjs && node scripts/build-content-v2.mjs",
    "copy:pyodide": "node scripts/copy-pyodide.mjs",
    "predev": "node scripts/copy-pyodide.mjs && node scripts/build-content-v2.mjs && node scripts/fetch-github-stats.mjs",
    "prebuild": "node scripts/copy-pyodide.mjs && node scripts/build-content-v2.mjs && node scripts/validate-solutions.mjs && node scripts/fetch-github-stats.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "check:content:v1": "node scripts/build-content.mjs",
    "check:content:v2": "node scripts/build-content-v2.mjs",
    "validate:solutions": "node scripts/validate-solutions.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm check:content:v2 && pnpm validate:solutions && pnpm build",
    "check:full": "pnpm lint && pnpm typecheck && pnpm check:content:v1 && pnpm check:content:v2 && pnpm validate:solutions && pnpm build",
    "smoke": "node scripts/smoke.mjs",
    "validate:sitemap": "node scripts/validate-sitemap.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "@uiw/react-codemirror": "^4.25.9",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.12.0",
    "next": "16.2.4",
    "pyodide": "^0.28.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
